---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../content/site.json";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/icons/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Commissioner:wght@100..900&family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
    <meta property="og:url" content="https://ilkestonaircadets.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content="348 (Ilkeston) Squadron RAF Air Cadets." />
    <meta property="og:image" content="https://ilkestonaircadets.com/images/home-banner.jpg" />
    <meta property="og:title" content="348 (Ilkeston) Squadron RAF Air Cadets" />
    <meta property="og:site_name" content="348 (Ilkeston) Squadron RAF Air Cadets" />
    <script type="application/ld+json">
    {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "348 (Ilkeston) Squadron RAF Air Cadets",
    "url": "https://ilkestonaircadets.com",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "Albert St",
        "addressLocality": "Ilkeston",
        "postalCode": "DE7 5GU",
        "addressCountry": "GB"
    }
    }
    </script>
    <title>{title ? `${title} | ${site.siteName}` : site.siteName}</title>
    <meta name="description" content={description}>
</head>
<body>
    <Header />
    <main>
        <slot />
    </main>
    <Footer />
</body>
</html>