---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home" description="Homepage">
    <div class="hero">
        <div class="image">
            <img src="https://pitfielddigital.github.io/qb-building-solutions/images/banners/homepage.png" alt="QB Building Solutions Homepage Banner" width="100%">
        </div>
        <div class="content">
            <h1 class="text-heading">QB BUILDING SOLUTIONS</h1>
            <div class="text">We offer anything from digging a hole to a new build</div>
            <hr class="hero-break">
            <div class="subtext">A reliable, professional and friendly team with a passion for building.</div>
            <a class="button btn btn-red" href="https://pitfielddigital.github.io/qb-building-solutions/contact">GET A QUOTE</a>
        </div>
    </div>
    <section>
        <div class="row row-2">
            <div class="column">
                <h2 class="text-heading">WELCOME TO QB BUILDING SOLUTIONS</h1>
                <h3 class="standout">Building Quality. Delivering Trust.</h3>
                <p class="page-text">QB Building solutions is a trusted building company based in Belper, Derbyshire. We provide a complete range of building services for domestic and commercial projects, big or small.</p>
                <a class="btn btn-white-red" href="https://pitfielddigital.github.io/qb-building-solutions/about">ABOUT US</a>
            </div>
            <div class="column">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/homepage-about.png" alt="QB Building Solutions House Project" width="100%">
                </div>
            </div>
        </div>
    </section>
    <section class="grey">
        <h2 class="text-heading">OUR SERVICES</h2>
        <h3 class="standout">From small jobs to large projects, we've got you covered.</h3>
        <div class="grid grid-4">
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/bricklaying.png" alt="Bricklaying" width="100%">
                </div>
                <div class="title">Bricklaying</div>
                <p class="page-text">High quality brickwork for new builds, extensions, garden walls and more.</p>
                <a class="card-button" href="https://pitfielddigital.github.io/qb-building-solutions/services/bricklaying">LEARN MORE</a>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/joinery.png" alt="Joinery" width="100%">
                </div>
                <div class="title">Joinery</div>
                <p class="page-text">Bespoke carpentry and joinery services, from doors to kitchen installations.</p>
                <a class="card-button" href="https://pitfielddigital.github.io/qb-building-solutions/services/joinery">LEARN MORE</a>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/site-management.png" alt="Site Management" width="100%">
                </div>
                <div class="title">Site Management</div>
                <p class="page-text">Professional site management to ensure your project runs smoothly.</p>
                <a class="card-button" href="https://pitfielddigital.github.io/qb-building-solutions/services/site-management">LEARN MORE</a>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/general-building.png" alt="General Building" width="100%">
                </div>
                <div class="title">General Building</div>
                <p class="page-text">From minor repairs to full renovations, we cover all aspects of building.</p>
                <a class="card-button" href="https://pitfielddigital.github.io/qb-building-solutions/services/general-building">LEARN MORE</a>
            </div>
        </div>
        <div class="spacer-15"></div>
        <a class="btn btn-red" href="https://pitfielddigital.github.io/qb-building-solutions/services">VIEW ALL SERVICES</a>
    </section>
    <section>
        <h2 class="text-heading">RECENT PROJECTS</h2>
        <h3 class="standout">Take a look at some of our recent work.</h3>
        <div class="grid grid-4">
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/bricklaying.png" alt="Bricklaying" width="100%">
                </div>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/joinery.png" alt="Joinery" width="100%">
                </div>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/site-management.png" alt="Site Management" width="100%">
                </div>
            </div>
            <div class="card">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/general-building.png" alt="General Building" width="100%">
                </div>
            </div>
        </div>
        <div class="spacer-15"></div>
        <a class="btn btn-white-red" href="https://pitfielddigital.github.io/qb-building-solutions/projects">VIEW ALL PROJECTS</a>
    </section>
    <section class="black">
        <h2 class="text-heading">WHY CHOOSE US?</h2>
        <div class="grid grid-4 bordered">
            <div class="item">
                <div class="icon"></div>
                <div class="title">Experienced</div>
                <p class="page-text">Years of industry experience delivering high quality results.</p>
            </div>
            <div class="item">
                <div class="icon"></div>
                <div class="title">Reliable</div>
                <p class="page-text">We pride ourselves on being reliable, professional and easy to work with.</p>
            </div>
            <div class="item">
                <div class="icon"></div>
                <div class="title">Fully Insured</div>
                <p class="page-text">We are fully insured for your peace of mind on every project.</p>
            </div>
            <div class="item">
                <div class="icon"></div>
                <div class="title">Local</div>
                <p class="page-text">Proud to serve Belper, Derby, and the surrounding Derbyshire areas.</p>
            </div>
        </div>
    </section>
</BaseLayout>