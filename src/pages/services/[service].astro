---
import BaseLayout from '../../layouts/BaseLayout.astro';
import services from '../../data/services.json';

export function getStaticPaths() {
  return Object.entries(services).map(([slug, service]) => ({
    params: { service: slug },
    props: { service }
  }));
}

const { service } = Astro.props;
const { service: slug } = Astro.params;
---

<BaseLayout title={service.title} description={service.title} menu="services">
    <div class="hero">
        <div class="image">
            <img src={`https://pitfielddigital.github.io/qb-building-solutions/images/banners/${slug}.png`} alt={service.title}>
        </div>
        <div class="content">
            <div class="text">{service.title}</div>
            <hr class="hero-break">
            <div class="subtext">{service.short_intro}</div>
        </div>
    </div>
    <section>
        <div class="row row-2">
            <div class="column">
                <h2 class="text-heading">{service.title}</h1>
                <div set:html={service.page_content} />
                <div class="spacer-35"></div>
                <a class="button btn btn-red" href="https://pitfielddigital.github.io/qb-building-solutions/contact">GET A QUOTE</a>
            </div>
            <div class="column">
                <div class="image">
                    <img src={`https://pitfielddigital.github.io/qb-building-solutions/images/${slug}.png`} alt={service.title} width="100%">
                </div>
            </div>
        </div>
    </section>
</BaseLayout>