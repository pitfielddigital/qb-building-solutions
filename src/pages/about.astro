---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About Us" description="About Us" menu="about">
    <div class="hero">
        <div class="image">
            <img src="https://pitfielddigital.github.io/qb-building-solutions/images/banners/homepage.png" alt="QB Building Solutions Homepage Banner">
        </div>
        <div class="content">
            <h1 class="text-heading">ABOUT US</h1>
            <div class="text">Building Quality, Delivering Trust.</div>
            <hr class="hero-break">
            <div class="subtext">QB Building Solutions is a trusted building company based in Belper, Derbyshire. We take pride in delivering high quality building work with a friendly, professional service you can rely on.</div>
        </div>
    </div>
    <section>
        <div class="row row-2">
            <div class="column">
                <h2 class="text-heading">WHO WE ARE</h1>
                <h3 class="standout">A local team you can trust.</h3>
                <div class="spacer-35"></div>
                <p class="page-text">
                    With years of experience in the building industry, we've build a reputation for quality workmanship, attention to detail, and a commitment to customer satisfaction.
                    <br><br>
                    We work with projects of all sizes, from small repairs to complete new builds, always deliver on time, on budget and to the highest standard.
                </p>
                <div class="spacer-35"></div>
                <a class="btn btn-white-red" href="https://pitfielddigital.github.io/qb-building-solutions/contact">GET IN TOUCH</a>
            </div>
            <div class="column">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/about-us.png" alt="About Us" width="100%">
                </div>
            </div>
        </div>
    </section>
    <section class="grey center">
        <h2 class="text-heading">OUR VALUES</h2>
        <h3 class="standout">What we stand for</h3>
        <div class="spacer-35"></div>
        <div class="grid grid-4 bordered">
            <div class="item">
                <div class="icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
                <div class="title">Quality Workmanship</div>
                <p class="item-text">We take pride in every project we complete, ensuring the highest standards every time.</p>
            </div>
            <div class="item">
                <div class="icon"><i class="fa-solid fa-handshake"></i></div>
                <div class="title">Reliable & Professional</div>
                <p class="item-text">We turn up when we say we will and keep you informed throughout the whole process.</p>
            </div>
            <div class="item">
                <div class="icon"><i class="fa-solid fa-scale-balanced"></i></div>
                <div class="title">Honest & Transparent</div>
                <p class="item-text">Clear communication, fair pricing and no hidden extras. What we say is what we do.</p>
            </div>
            <div class="item">
                <div class="icon"><i class="fa-solid fa-map-location-dot"></i></div>
                <div class="title">Local & Trusted</div>
                <p class="item-text">Based in Belper, we're proud to serve our local community and surrounding areas.</p>
            </div>
        </div>
    </section>
    <section class="center">
        <h2 class="text-heading">OUR PROCESS</h2>
        <h3 class="standout">Build on a simple process</h3>
        <div class="spacer-35"></div>
        <div class="our-process">
            <div class="process">
                <div class="number">1</div>
                <div class="title">Discuss</div>
                <p class="process-text">We listen to your ideas and requirements to understand your project.</p>
            </div>
            <div class="arrow"><i class="fa-solid fa-caret-right"></i></div>
            <div class="process">
                <div class="number">2</div>
                <div class="title">Plan</div>
                <p class="process-text">We provide expert advice and a clear plan to bring your vision to life.</p>
            </div>
            <div class="arrow"><i class="fa-solid fa-caret-right"></i></div>
            <div class="process">
                <div class="number">3</div>
                <div class="title">Build</div>
                <p class="process-text">Our skilled team gets to work, keeping you updated every step of the way.</p>
            </div>
            <div class="arrow"><i class="fa-solid fa-caret-right"></i></div>
            <div class="process">
                <div class="number">4</div>
                <div class="title">Deliver</div>
                <p class="process-text">We complete your project to the highest standard, on time and on a budget.</p>
            </div>
        </div>
    </section>
    <section>
        <div class="row row-2">
            <div class="column">
                <div class="image">
                    <img src="https://pitfielddigital.github.io/qb-building-solutions/images/why-us.png" alt="Why Choose Us" width="100%">
                </div>
            </div>
            <div class="column">
                <h2 class="text-heading">WHY CHOOSE US</h1>
                <h3 class="standout">We go the extra mile</h3>
                <div class="spacer-35"></div>
                <ul>
                    <li>Fully insured for your peace of mind</li>
                    <li>Experienced in domestic and commercial projects</li>
                    <li>High quality materials and trusted suppliers</li>
                    <li>Attention to detail from start to finish</li>
                    <li>Customer satisfaction is our priority</li>
                </ul>
                <div class="spacer-35"></div>
                <a class="btn btn-red" href="https://pitfielddigital.github.io/qb-building-solutions/services">VIEW OUR SERVICES</a>
            </div>
        </div>
    </section>
</BaseLayout>